# Copy to .env (optional — compose falls back to these same defaults).
# MinIO (S3-compatible object store)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
S3_BUCKET=datalake

# S3 client config (Spark s3a + boto3 ingestion) — point at MinIO
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_REGION=us-east-1

# Spark (inside the cluster the jobs target the standalone master;
# unset / local runs default to local[*])
SPARK_MASTER=spark://spark-master:7077

# Ingestion source
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TLC_DATASET=yellow
